{
  "layer": "top",
  "position": "top",
  "margin-bottom": -10,
  "spacing" : 0,

  "modules-left": [
    "hyprland/workspaces",
  ],

  "modules-center": ["clock"],

  "modules-right": [
    "cpu",
    "memory",
    "bluetooth",
    "network",
